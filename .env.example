# Copy to .env and edit. Compose reads it automatically.

# Postgres password (used by db + backend DATABASE_URL).
DB_PASSWORD=changeme

# 32+ random bytes. Generate: openssl rand -hex 32
SESSION_SECRET=

# Public reachable endpoint of the VPS hub that clients + nodes dial.
HUB_ENDPOINT=203.0.113.10:51820

# VPN pool + hub tunnel address (defaults are fine for most).
HUB_POOL_CIDR=10.8.0.0/24
HUB_ADDRESS=10.8.0.1
# Host's internet-facing interface, used to masquerade full-tunnel (internet
# exit) clients. Find it with: ip route get 1.1.1.1
HUB_WAN_IFACE=eth0

# Optional global DNS pushed to all clients (empty = none). Per-client override in UI.
HUB_DNS=

# Split-horizon DNS resolver: clients use the hub tunnel IP as DNS, and it
# forwards each domain to the DNS of the node that owns it. Set per-node domains
# in the panel. Empty RESOLVER_LISTEN disables it. Default upstream for the rest:
RESOLVER_LISTEN=10.8.0.1:5354
DNS_UPSTREAM=1.1.1.1:53

# Shared secret nodes must present to self-enroll. Give this to each node at
# install time. Generate: openssl rand -hex 24. Empty disables enrollment.
HUB_ENROLL_SECRET=

# First admin, created on first boot only.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Set to 1 while serving plain HTTP. Set empty once TLS terminates in front.
INSECURE_COOKIES=1
