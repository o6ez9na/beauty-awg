# Copy to .env and edit. Compose reads it automatically.

# Postgres password (used by db + backend DATABASE_URL).
DB_PASSWORD=changeme

# 32+ random bytes. Generate: openssl rand -hex 32
SESSION_SECRET=

# Public reachable endpoint of the VPS hub that clients + nodes dial.
HUB_ENDPOINT=203.0.113.10:51820

# VPN pool + hub tunnel address (defaults are fine for most).
HUB_POOL_CIDR=10.8.0.0/24
HUB_ADDRESS=10.8.0.1
# Optional global DNS pushed to all clients (empty = none). Per-client override in UI.
HUB_DNS=

# First admin, created on first boot only.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Set to 1 while serving plain HTTP. Set empty once TLS terminates in front.
INSECURE_COOKIES=1
